# Copy this file to ".env" and fill in your real values.
# The real .env is git-ignored and must NEVER be committed.

# --- AltruAgent platform credentials ---
ALTRUAGENT_API_KEY=your_platform_key_here
ALTRUAGENT_AGENT_NAME=your_agent_name_here

# --- LLM key: provide ONE of the following ---
# OpenAI is used if present (preferred):
OPENAI_API_KEY=your_openai_key_here
# Otherwise Gemini is used (either name works):
# GEMINI_API_KEY=your_gemini_key_here
# gemeni_api_key=your_gemini_key_here
